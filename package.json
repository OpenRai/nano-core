{
  "name": "@openrai/nano-core",
  "version": "2.4.0",
  "description": "Protocol engine for Nano integration ecosystem",
  "repository": "https://github.com/OpenRai/nano-core",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./transport": {
      "import": "./dist/transport/index.js",
      "types": "./dist/transport/index.d.ts"
    },
    "./transport/http": {
      "import": "./dist/transport/http.js",
      "types": "./dist/transport/http.d.ts"
    },
    "./transport/ws": {
      "import": "./dist/transport/ws.js",
      "types": "./dist/transport/ws.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "keywords": [
    "nano",
    "xno",
    "cryptocurrency"
  ],
  "author": "OpenRai",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "blakejs": "^1.2.1",
    "nano-pow-with-fallback": "^1.1.2",
    "nanocurrency": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
